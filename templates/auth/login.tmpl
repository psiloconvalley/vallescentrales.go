{{define "content"}}
<div class="auth-container">
    <h1>Ingresar</h1>

    {{if .Error}}
    <div class="flash flash-error">{{.Error}}</div>
    {{end}}

    <form method="POST" action="/auth/login" autocomplete="on" novalidate>
        <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">

        <div class="form-group">
            <label class="form-label" for="email">Correo Electrónico</label>
            <input class="form-input" type="email" id="email" name="email"
                   value="{{if .FormData}}{{.FormData.Email}}{{end}}"
                   required autocomplete="email" placeholder="tu@correo.com">
        </div>

        <div class="form-group">
            <label class="form-label" for="password">Contraseña</label>
            <div class="form-input-wrap">
                <input class="form-input" type="password" id="password" name="password"
                       required autocomplete="current-password"
                       placeholder="Tu contraseña">
                <span class="password-toggle" id="passwordToggle" role="button" tabindex="0" aria-label="Mostrar contraseña"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-primary btn-block">Ingresar</button>
    </form>

    <div class="auth-footer">
        ¿No tienes cuenta? <a href="/auth/register">Crear cuenta</a>
    </div>

    <div class="auth-divider">o</div>

    <div class="auth-alt-methods">
        <div id="passkeySection">
            <button id="passkeyLoginBtn" class="btn btn-secondary btn-block" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                Continuar con Passkey
            </button>
            <span id="passkeyLoginStatus" class="passkey-status"></span>
        </div>

        {{if .GoogleEnabled}}
        <a href="/auth/google" class="btn btn-google btn-block">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continuar con Google
        </a>
        {{end}}
    </div>
</div>
{{end}}
