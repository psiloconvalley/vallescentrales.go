{{define "content"}}
<div class="container">

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-avatar">
            {{if .User}}
                {{slice .User.FullName 0 1}}
            {{end}}
        </div>
        <div class="profile-info">
            <h1>{{if .User}}{{.User.FullName}}{{end}}</h1>
            <p class="text-muted">{{if .User}}{{.User.Email}}{{end}}</p>
            {{if .User}}
                {{if .User.IsGoogleUser}}
                <span class="auth-badge auth-badge-google">
                    <svg width="12" height="12" viewBox="0 0 24 24" style="display:inline;vertical-align:middle;margin-right:4px">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Google
                </span>
                {{else}}
                <span class="auth-badge auth-badge-email">Email</span>
                {{end}}
            {{end}}
        </div>
    </div>

    <!-- Dashboard Actions -->
    <div class="dashboard-header">
        <div>
            <h2>Mis Propiedades</h2>
            <p class="text-muted text-sm">{{len .Listings}} propiedad{{if ne (len .Listings) 1}}es{{end}} registrada{{if ne (len .Listings) 1}}s{{end}}</p>
        </div>
        <a href="/listings/new" class="btn btn-primary">+ Publicar Propiedad</a>
    </div>

    {{if .Listings}}
        <div class="dashboard-table-wrap">
            <table class="dashboard-table">
                <thead>
                    <tr>
                        <th>Propiedad</th>
                        <th>Tipo</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{range .Listings}}
                    <tr>
                        <td>
                            <div style="font-weight:600; color:var(--obsidian);">{{.Title}}</div>
                            <div class="text-xs text-light mt-1">{{.Municipality}}</div>
                        </td>
                        <td><span class="badge badge-{{.PropertyType}}">{{.PropertyType}}</span></td>
                        <td class="font-mono text-sm">${{printf "%.0f" .PriceMXN}} MXN</td>
                        <td><span class="status status-{{.Status}}">{{.Status}}</span></td>
                        <td class="text-right">
                            <div style="display:flex;gap:8px;justify-content:flex-end;">
                                <a href="/listings/{{.Slug}}/edit" class="btn btn-secondary btn-sm">Editar</a>
                                <a href="/listings/{{.Slug}}" class="btn btn-secondary btn-sm" target="_blank">Ver</a>
                            </div>
                        </td>
                    </tr>
                    {{end}}
                </tbody>
            </table>
        </div>
    {{else}}
        <div class="empty-state">
            <h2>Aún no tienes propiedades</h2>
            <p>Comienza publicando tu primer terreno o casa en los Valles Centrales.</p>
            <a href="/listings/new" class="btn btn-primary mt-3">Publicar Ahora →</a>
        </div>
    {{end}}

</div>
{{end}}
